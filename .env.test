# MongoDB for local tests from host machine
DB_NAME=liar_test
DB_CONN_STRING=mongodb://admin:password@127.0.0.1:27017/?authSource=admin&replicaSet=rs0&directConnection=true

# Auth
SECRET=test-secret
JWT_EXPIRES_IN=1d
TELEGRAM_BOT_TOKEN=test-bot-token
TELEGRAM_INITDATA_EXPIRES_IN=3600

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limit
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=30

# Game
SCORE_NOT_STATED=50
SCORE_TRICKED=100
GAME_STAGE_TIMER_MS=1000
HIDDEN_DURING_GAME_FIELDS=doLie,questionHistory,liarId,timerId
GAME_RESULTS_FIELDS=doLie,loserTask,winnerId,loserId

# Lobby
LOBBY_CODE_ALPHABET=ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789
LOBBY_CODE_LENGTH=6

# Tests
RUN_INTEGRATION_TESTS=1
