FROM oven/bun:1.3.5-alpine

WORKDIR /app

# Vite dev proxy в Bun падает на socket.destroySoon, поэтому dev-сервер запускаем через Node runtime.
RUN apk add --no-cache nodejs npm

# Копируем только манифесты workspace для максимального кеширования install слоя
COPY package.json bun.lock ./
COPY apps/backend/package.json ./apps/backend/package.json
COPY apps/frontend/package.json ./apps/frontend/package.json
COPY apps/admin/package.json ./apps/admin/package.json
COPY packages/shared/package.json ./packages/shared/package.json
COPY packages/message-types/package.json ./packages/message-types/package.json

ARG VITE_TELEGRAM_BOT_URL
ENV VITE_TELEGRAM_BOT_URL=$VITE_TELEGRAM_BOT_URL

# Детерминированная установка зависимостей по lockfile
RUN bun install --frozen-lockfile

EXPOSE 5173

# Запуск Vite dev server (код монтируется volume'ами из docker-compose)
WORKDIR /app/apps/frontend
CMD ["npm", "run", "dev"]
