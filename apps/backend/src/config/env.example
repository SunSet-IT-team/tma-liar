# Строка подключения к MongoDB
DB_CONN_STRING="mongodb://localhost:27017"

# Имя базы данных
DB_NAME="liar"

# Название коллекции пользователей
USERS_COLLECTION_NAME="users"

# Название коллекции лобби (игровых комнат)
LOBBIES_COLLECTION_NAME="lobbies"

# Название коллекции колод (deck)
DECKS_COLLECTION_NAME="decks"

# Секрет для подписи JWT (обязательно в проде)
SECRET="mega-secret"

# Время жизни токена (например 1d, 7d, 24h)
JWT_EXPIRES_IN="1d"

# Порт HTTP-сервера
PORT="3000"

# Очки, если ответ "не определился"
SCORE_NOT_STATED="50"

# Очки, если лжецу удалось обмануть
SCORE_TRICKED="100"

# Интервал таймера авто-перехода стадий (мс)
GAME_STAGE_TIMER_MS="1000"

# Поля игры, скрытые во время раунда (кроме GAME_RESULTS), через запятую
HIDDEN_DURING_GAME_FIELDS="doLie,questionHistory,liarId,timerId"

# Поля, отдаваемые только в стадии GAME_RESULTS, через запятую
GAME_RESULTS_FIELDS="doLie,loserTask,winnerId,loserId"

# Символы для кода лобби (nanoid)
LOBBY_CODE_ALPHABET="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"

# Длина кода лобби
LOBBY_CODE_LENGTH="6"

