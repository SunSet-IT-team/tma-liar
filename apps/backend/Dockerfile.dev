# Dev Dockerfile для backend с hot-reload
FROM oven/bun:1.3.5-alpine

WORKDIR /app

# Копируем только манифесты workspace для максимального кеширования install слоя
COPY package.json bun.lock ./
COPY apps/backend/package.json ./apps/backend/package.json
COPY apps/frontend/package.json ./apps/frontend/package.json
COPY apps/deckEditor/package.json ./apps/deckEditor/package.json
COPY packages/shared/package.json ./packages/shared/package.json
COPY packages/message-types/package.json ./packages/message-types/package.json

# Детерминированная установка зависимостей по lockfile
RUN bun install --frozen-lockfile

EXPOSE 3000

# Запуск в dev режиме с watch (код монтируется volume'ами из docker-compose)
WORKDIR /app/apps/backend
CMD ["bun", "--watch", "src/index.ts"]
