game-lier.ru, www.game-lier.ru {
  encode zstd gzip

  @api path /api/* /uploads/* /socket.io/*
  handle @api {
    reverse_proxy backend:3000
  }

  @admin path /admin* 
  handle @admin {
    reverse_proxy admin:5175
  }

  @frontend path_regexp ^/(?!api|admin).*$
  handle @frontend {
      reverse_proxy frontend:80
  }
}