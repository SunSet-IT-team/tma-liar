(app) {
  encode zstd gzip

  @api path /api/* /uploads/* /socket.io/*
  handle @api {
    reverse_proxy backend:3000
  }

  handle_path /admin/* {
    reverse_proxy admin:80
  }

  handle_path /admin {
    reverse_proxy admin:80
  }

  handle {
    reverse_proxy frontend:80
  }
}

game-lier.ru, www.game-lier.ru {
  import app
}

http://localhost {
  import app
}